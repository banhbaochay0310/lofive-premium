# ============================================
# Docker Compose Environment Variables
# Copy to .env and customize for your deployment
# ============================================

# Database
DB_USER=postgres
DB_PASSWORD=your-strong-db-password

# JWT
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_EXPIRES_IN=24h

# URLs
FRONTEND_URL=http://localhost
VITE_API_URL=/api/v1
